# Django
DJANGO_SECRET_KEY=changeme-use-a-long-random-string
DEBUG=False
ALLOWED_HOSTS=kolco24.ru,xn--24-1lceob9c6b.xn--p1ai,kolco-24.ru
CSRF_TRUSTED_ORIGINS=https://kolco24.ru,https://xn--24-1lceob9c6b.xn--p1ai,https://kolco-24.ru

# Database — Django
DB_NAME=kolco24
DB_USER=kolco24
DB_PASSWORD=
DB_HOST=kolco24_db
DB_PORT=5432

# Database — PostgreSQL container
POSTGRES_DB=kolco24
POSTGRES_USER=kolco24
POSTGRES_PASSWORD=

# Email (Yandex SMTP)
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=

# Yandex payments
YANDEX_WALLET=
YANDEX_NOTIFICATION_SECRET=

# Sberbank
SBERBANK_PHONE=
SBERBANK_NAME=

# SBP
SBP_PHONE=
SBP_NAME=

# VTB
VTB_ENV=prod
VTB_CLIENT_ID=
VTB_CLIENT_SECRET=
VTB_CLIENT_ID_HEADER=
VTB_MERCHANT_AUTH=
VTB_RETURN_URL_BASE=

# Contributors API (used by tk-sputnik.org sync_contributors)
CONTRIBUTORS_API_TOKEN=

# JSON map of key-id -> shared secret. Each app build ships one key-id + its secret.
# Keep >=2 keys active during a rotation overlap; drop a key only when no install reports it.
# Must be valid JSON (quoted keys AND values); malformed/empty -> all /app/* requests 403
# and a "MOBILE_APP_KEYS malformed or empty" WARNING is logged at startup.
MOBILE_APP_KEYS={"android-v1":"","ios-v1":""}
# Mobile app sync manifest data-source tag ("cloud" default; set to "local" on race-day server)
MOBILE_DATA_SOURCE=cloud

# Backup
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30

# Trusted upstream proxy CIDR for nginx real_ip resolution.
# REQUIRED — docker-compose_v2.yml will refuse to start without it.
# This variable is read from the HOST shell environment or the project .env
# file (same file as KOLCO24_IMAGE / DATA_LOCATION) — NOT from this file.
# Set it to the reverse-proxy container's specific IP for tightest isolation:
#   echo "TRUSTED_PROXY_CIDR=172.18.0.2/32" >> .env   # use /32 for a single IP
# Find the value with: docker network inspect proxy | grep -E '"Subnet"|"IPv4Address"'
# Never use a range broader than the proxy's dedicated network subnet.
