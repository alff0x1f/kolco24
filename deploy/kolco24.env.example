MOBILE_APP_KEYS={"android-v1":"","ios-v1":""}
# Mobile app sync manifest data-source tag ("cloud" default; set to "local" on race-day server)
MOBILE_DATA_SOURCE=cloud

# Backup
BACKUP_DIR=/app/backups
BACKUP_RETENTION_DAYS=30
